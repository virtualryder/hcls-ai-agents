# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic                 # anthropic | bedrock
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx      # required for anthropic provider
# CLAUDE_NARRATIVE_MODEL=claude-sonnet-4-6
# CLAUDE_FAST_MODEL=claude-haiku-4-5

# ── Bedrock (in-account inference; data does not leave your AWS account) ───────
# BEDROCK_REGION=us-east-1
# BEDROCK_NARRATIVE_MODEL_ID=anthropic.claude-sonnet-4-6-20260601-v1:0
# BEDROCK_GUARDRAIL_ID=                 # REQUIRED in production (PHI/off-label filters)
# BEDROCK_GUARDRAIL_VERSION=DRAFT
# REQUIRE_BEDROCK_GUARDRAIL=1           # refuse to start un-guardrailed in prod

# ── Connectors / gateway ──────────────────────────────────────────────────────
CONNECTOR_MODE=fixture                 # fixture (demo) | live (production)
AUTH_ROLE_CLAIM=custom:hcls_role
# AUTH_JWKS_URL=                        # IdP JWKS for token verification (prod)
# AUTH_AUDIENCE=

# ── Persistence ───────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/regwriting   # PostgresSaver in prod

# ── Demo ──────────────────────────────────────────────────────────────────────
EXTRACT_MODE=demo                      # demo => deterministic drafts, no API key needed
ENVIRONMENT=dev
