# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic                 # anthropic | bedrock
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx      # required for anthropic provider
# ── Bedrock (in-account inference; data never leaves your AWS account) ─────────
# LLM_PROVIDER=bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_GUARDRAIL_ID=                 # REQUIRED in production
# REQUIRE_BEDROCK_GUARDRAIL=1
# ENVIRONMENT=production
# ── Connectors / gateway ──────────────────────────────────────────────────────
CONNECTOR_MODE=fixture                 # fixture (demo/CI) | live (production)
AUTH_ROLE_CLAIM=custom:hcls_role
# AUTH_JWKS_URL=                        # IdP JWKS for token verification (prod)
# ── MES / LIMS — live connectors (CONNECTOR_MODE=live) ────────────────────────
# MES_BASE_URL=https://your-mes-gateway.example.com    # Körber/Tulip/Rockwell/AVEVA
# MES_API_TOKEN=                        # (or via AWS Secrets Manager at hcls/mes_api_token)
# LIMS_BASE_URL=https://your-lims-gateway.example.com
# LIMS_API_TOKEN=
# ── Persistence ───────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/batchreview
# ── Demo / CI ─────────────────────────────────────────────────────────────────
EXTRACT_MODE=demo                      # demo => deterministic reports, no API key needed
ENVIRONMENT=dev
DISABLE_SECRETS_MANAGER=1
