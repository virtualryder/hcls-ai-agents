# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic                 # anthropic | bedrock
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx      # required for anthropic provider
# CLAUDE_NARRATIVE_MODEL=claude-sonnet-4-6
# CLAUDE_FAST_MODEL=claude-haiku-4-5

# ── Bedrock (in-account inference; PHI never leaves your AWS account) ──────────
# LLM_PROVIDER=bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_NARRATIVE_MODEL_ID=anthropic.claude-sonnet-4-6-20260601-v1:0
# BEDROCK_FAST_MODEL_ID=anthropic.claude-haiku-4-5-20251001
# BEDROCK_GUARDRAIL_ID=                 # REQUIRED in production (PHI/off-label filters)
# BEDROCK_GUARDRAIL_VERSION=DRAFT
# REQUIRE_BEDROCK_GUARDRAIL=1           # refuse to start un-guardrailed in prod
# ENVIRONMENT=production                # enforces guardrail requirement

# ── Connectors / gateway ──────────────────────────────────────────────────────
CONNECTOR_MODE=fixture                 # fixture (demo/CI) | live (production)
AUTH_ROLE_CLAIM=custom:hcls_role
# AUTH_JWKS_URL=                        # IdP JWKS for token verification (prod)
# AUTH_AUDIENCE=

# ── Safety database — live connector (CONNECTOR_MODE=live) ────────────────────
# SAFETY_BASE_URL=http://127.0.0.1:8099  # local reference service (demo/test)
# SAFETY_BASE_URL=https://your-argus-gateway.example.com  # real Argus/Veeva endpoint
# SAFETY_API_TOKEN=                      # Bearer token for the safety endpoint
#                                        # (or set via AWS Secrets Manager at hcls/safety_api_token)
# SAFETY_PORT=8099                       # port for local reference_safety_service.py

# ── Medical dictionaries (licensed — remain fixture-backed in demo) ────────────
# MEDDRA_API_KEY=                        # Licensed MedDRA browser API key (prod)
# WHODRUG_API_KEY=                       # Licensed WHODrug API key (prod)

# ── Persistence ───────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/pharmacovig   # PostgresSaver in prod

# ── Demo / CI ─────────────────────────────────────────────────────────────────
EXTRACT_MODE=demo                      # demo => deterministic narratives, no API key needed
ENVIRONMENT=dev
DISABLE_SECRETS_MANAGER=1             # set to 1 in CI/local (skips boto3 Secrets Manager)
